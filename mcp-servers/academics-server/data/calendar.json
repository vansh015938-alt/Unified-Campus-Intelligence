  "courses": {
    "CS101": {
      "title": "Introduction to Computer Science",
      "credits": 4,
      "prerequisites": "None",
      "instructor": "Dr. Sarah Miller (s.miller@campuspulse.edu)",
      "syllabus_summary": "Introduction to computation, algorithms, variables, control flow, loops, functions, lists, basic searching/sorting, and object-oriented programming principles using Python."
    },
    "CS202": {
      "title": "Data Structures and Algorithms",
      "credits": 4,
      "prerequisites": "CS101",
      "instructor": "Dr. Thomas Cormen (t.cormen@campuspulse.edu)",
      "syllabus_summary": "Study of arrays, linked lists, stacks, queues, trees, binary search trees, AVL trees, graphs, sorting algorithms, searching, hashing, and space/time complexity analysis."
    },
    "EE201": {
      "title": "Analog Electronics",
      "credits": 3,
      "prerequisites": "AP Physics II",
      "instructor": "Prof. Adel Sedra (a.sedra@campuspulse.edu)",
      "syllabus_summary": "Semiconductor diodes, bipolar junction transistors (BJTs), field effect transistors (FETs), biasing, small-signal models, single-stage amplifiers, operational amplifiers (op-amps), and frequency response."
    },
    "CS304": {
      "title": "Operating Systems",
      "credits": 4,
      "prerequisites": "CS202 & Computer Architecture",
      "instructor": "Dr. Abraham Silberschatz (a.silberschatz@campuspulse.edu)",
      "syllabus_summary": "Operating system design, process management, CPU scheduling, threads, synchronization, deadlocks, memory management, virtual memory, file systems, and input/output systems."
    },
    "HU102": {
      "title": "Introduction to Philosophy",
      "credits": 3,
      "prerequisites": "None",
      "instructor": "Dr. Robin Waterfield (r.waterfield@campuspulse.edu)",
      "syllabus_summary": "Historical introduction to Western philosophical thought, covering Epistemology (knowledge), Metaphysics (existence), Ethics (morality), and Philosophy of Mind."
    }
  },
